      "localizations" : {
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Esto ayuda a mejorar la precisión de la transcripción." } }
      }
    },
    "Set up a keyboard shortcut to quickly access Nexo Whisper from anywhere." : {
      "localizations" : {
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Configurá un atajo de teclado para acceder rápidamente a Nexo Whisper desde cualquier lugar." } }
