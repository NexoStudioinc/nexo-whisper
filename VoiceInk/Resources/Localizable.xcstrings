    "Automatically delete transcript history based on the retention period you set." : { "localizations" : { "es" : { "stringUnit" : { "state" : "translated", "value" : "Eliminá automáticamente el historial de transcripciones según el período que configures." } } } },
    "Automatically presses a key combination after pasting text. Useful for chat applications or forms that use different send shortcuts." : { "localizations" : { "es" : { "stringUnit" : { "state" : "translated", "value" : "Presiona una combinación de teclas automáticamente después de pegar texto. Útil para chats o formularios con atajos de envío distintos." } } } },
