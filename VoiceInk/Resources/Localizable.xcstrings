            "state": "translated",
            "value": "Aplica configuraciones personalizadas automáticamente según la app o sitio que estés usando."
          }
        }
      }
    },
    "Automatically delete audio recordings while keeping text transcripts intact.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Eliminá grabaciones de audio automáticamente conservando las transcripciones de texto."
          }
        }
      }
    },
    "Automatically delete transcript history based on the retention period you set.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Eliminá automáticamente el historial de transcripciones según el período que configures."
          }
        }
      }
    },
    "Automatically presses a key combination after pasting text. Useful for chat applications or forms that use different send shortcuts.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Presiona una combinación de teclas automáticamente después de pegar texto. Útil para chats o formularios con atajos de envío distintos."
          }
        }
      }
    },
    "Automatically remove filler words like 'uh', 'um', 'hmm' from transcriptions.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Eliminá automáticamente muletillas como 'eh', 'um', 'hmm' de las transcripciones."
          }
        }
      }
    },
    "Automatically replace specific words/phrases with custom formatted text": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Reemplazá automáticamente palabras o frases con texto formateado a medida"
          }
        }
      }
    },
    "Automatically skip AI enhancement when the transcription has very few words. Short phrases like \"yes\", \"thank you\", or quick commands don't benefit from enhancement.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Saltea la mejora con IA cuando la transcripción tiene muy pocas palabras. Frases cortas como \"sí\", \"gracias\" o comandos rápidos no se benefician de la mejora."
          }
        }
      }
    },
