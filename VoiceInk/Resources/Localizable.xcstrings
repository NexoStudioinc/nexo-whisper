    "Apple's on-device model: free, private and offline.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Modelo on-device de Apple: gratis, privado y sin conexión."
          }
        }
      }
    },
    "Next": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Siguiente"
          }
        }
      }
    }
  }
}
