      }
    },
    "Default uses simulated Cmd+V key events. AppleScript can help when custom keyboard layouts do not paste correctly." : {
      "localizations" : {
        "es" : { "stringUnit" : { "state" : "translated", "value" : "El método predeterminado simula Cmd+V. AppleScript puede ayudar cuando algunos layouts de teclado no pegan correctamente." } }
      }
    },
    "Devices will be used in order of priority. If a device is unavailable, the next one will be tried. If no prioritized device is available, the built-in microphone will be used." : {
      "localizations" : {
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Los dispositivos se usan según su orden de prioridad. Si uno no está disponible, se prueba el siguiente. Si ninguno priorizado está disponible, se usa el micrófono interno." } }
      }
    },
