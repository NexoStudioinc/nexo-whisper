    },
    "Control how Nexo Whisper handles your transcription data and audio recordings." : {
      "localizations" : {
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Controlá cómo Nexo Whisper maneja tus transcripciones y grabaciones de audio." } }
