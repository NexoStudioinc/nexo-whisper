    "Enable your microphone to start speaking and converting your voice to text instantly." : {
      "localizations" : {
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Habilitá tu micrófono para empezar a hablar y convertir tu voz en texto al instante." } }
