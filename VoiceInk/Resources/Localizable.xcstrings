        "es" : { "stringUnit" : { "state" : "translated", "value" : "Bienvenido al futuro de escribir" } }
      }
    },
    "We'll download the optimized model to get you started." : {
      "localizations" : {
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Vamos a descargar el modelo optimizado para que puedas arrancar." } }
